@using MediatR
@using FurnitureERP.Application.Employees.DTOs
@using FurnitureERP.Application.Employees.Queries.GetEmployeeWorkload
@inject IMediator Mediator
@inject NotificationService NotificationService
@inject DialogService DialogService

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" style="padding: 2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (workload != null)
{
    <RadzenStack Gap="1rem">

        @* Informace o zaměstnanci *@
        <RadzenCard>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color)">Jméno</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1"><strong>@workload.FullName</strong></RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color)">Pozice</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1">@workload.Position</RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color)">Hodinová sazba</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1">@workload.HourlyRate.ToString("N0") Kč/h</RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color)">Stav</RadzenText>
                        <RadzenBadge BadgeStyle="@(workload.IsActive ? BadgeStyle.Success : BadgeStyle.Danger)"
                                     Text="@(workload.IsActive ? "Aktivní" : "Neaktivní")" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        @* Aktivní zakázky *@
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenText TextStyle="TextStyle.H6" style="margin: 0">Aktivní zakázky</RadzenText>
            @if (workload.ActiveOrders.Any())
            {
                <RadzenBadge BadgeStyle="BadgeStyle.Warning"
                             Text="@($"{workload.ActiveOrders.Sum(a => a.FairShareHours):N1} h")" />
            }
        </RadzenStack>

        @if (!workload.ActiveOrders.Any())
        {
            <RadzenCard>
                <RadzenText style="color: var(--rz-text-secondary-color); text-align: center; padding: 1rem;">
                    Žádné aktivní zakázky
                </RadzenText>
            </RadzenCard>
        }
        else
        {
            <RadzenDataGrid Data="@workload.ActiveOrders"
                            TItem="EmployeeOrderAssignmentDto"
                            AllowPaging="false"
                            AllowSorting="false"
                            AllowFiltering="false">
                <Columns>
                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Property="OrderNumber"
                                          Title="Zakázka"
                                          Width="110px" />

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Property="CustomerName"
                                          Title="Zákazník" />

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Property="ProductName"
                                          Title="Výrobek" />

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Title="Ks"
                                          Width="60px">
                        <Template Context="a">
                            @a.Quantity
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Title="h/ks"
                                          Width="80px">
                        <Template Context="a">
                            @a.HoursPerUnit.ToString("N1")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Title="Hodin"
                                          Width="90px">
                        <Template Context="a">
                            <strong>@a.FairShareHours.ToString("N1") h</strong>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="EmployeeOrderAssignmentDto"
                                          Title="Dokončení"
                                          Width="120px">
                        <Template Context="a">
                            @(a.ExpectedCompletionDate.HasValue
                                ? a.ExpectedCompletionDate.Value.ToString("dd.MM.yyyy")
                                : "—")
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="Zavřít"
                          ButtonStyle="ButtonStyle.Light"
                          Icon="close"
                          Click="@(() => DialogService.Close())" />
        </RadzenStack>
    </RadzenStack>
}

@code {
    [Parameter]
    public int EmployeeId { get; set; }

    private EmployeeWorkloadDto? workload;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            workload = await Mediator.Send(new GetEmployeeWorkloadQuery(EmployeeId));
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Chyba",
                Detail = ex.Message,
                Duration = 4000
            });
            DialogService.Close();
        }
        finally
        {
            isLoading = false;
        }
    }
}
