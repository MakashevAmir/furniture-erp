@page "/employees"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Manager")]
@using MediatR
@using FurnitureERP.Application.Employees.Queries.GetEmployees
@using FurnitureERP.Application.Employees.Commands.DeleteEmployee
@using FurnitureERP.Application.Employees.DTOs
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NotificationService NotificationService
@inject DialogService DialogService

<PageTitle>Zaměstnanci - FurnitureERP</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" style="margin: 0">
                Zaměstnanci
            </RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-md-end">
            <RadzenButton Icon="add_circle_outline"
                          Text="Přidat zaměstnance"
                          Click="@CreateEmployee"
                          ButtonStyle="ButtonStyle.Primary" />
        </RadzenColumn>
    </RadzenRow>

    @if (isLoading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        @* Souhrnné karty kapacity *@
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard style="text-align:center; padding: 1rem;">
                    <RadzenText TextStyle="TextStyle.H4" style="margin:0; color: var(--rz-primary)">
                        @activeEmployees.Count
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color)">
                        aktivních zaměstnanců
                    </RadzenText>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard style="text-align:center; padding: 1rem;">
                    <RadzenText TextStyle="TextStyle.H4" style="margin:0; color: var(--rz-success)">
                        @(activeEmployees.Count * 8) h/den
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color)">
                        celková denní kapacita
                    </RadzenText>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard style="text-align:center; padding: 1rem;">
                    <RadzenText TextStyle="TextStyle.H4" style="margin:0; color: var(--rz-warning)">
                        @groups.Count
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color)">
                        pracovních rolí
                    </RadzenText>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        @* Skupiny podle pozice *@
        @foreach (var group in groups)
        {
            var activeInGroup = group.Value.Where(e => e.IsActive).ToList();
            var totalInGroup = group.Value.Count;

            <RadzenCard>
                <RadzenRow AlignItems="AlignItems.Center" style="margin-bottom: 0.75rem;">
                    <RadzenColumn>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                            <RadzenText TextStyle="TextStyle.H6" style="margin:0">
                                @group.Key
                            </RadzenText>
                            <RadzenBadge BadgeStyle="BadgeStyle.Primary"
                                         Text="@($"{activeInGroup.Count} aktivních")" />
                            @if (activeInGroup.Count != totalInGroup)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Light"
                                             Text="@($"{totalInGroup - activeInGroup.Count} neaktivních")" />
                            }
                            <RadzenText TextStyle="TextStyle.Caption"
                                        style="color: var(--rz-text-secondary-color); margin:0">
                                @(activeInGroup.Count * 8) h/den
                            </RadzenText>
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenDataGrid Data="@group.Value"
                                TItem="EmployeeDto"
                                AllowPaging="false"
                                AllowSorting="false"
                                AllowFiltering="false"
                                Style="border: none;">
                    <Columns>
                        <RadzenDataGridColumn TItem="EmployeeDto"
                                              Property="FullName"
                                              Title="Jméno"
                                              Width="220px" />

                        <RadzenDataGridColumn TItem="EmployeeDto"
                                              Property="HourlyRate"
                                              Title="Sazba (Kč/h)"
                                              Width="130px">
                            <Template Context="emp">
                                @emp.HourlyRate.ToString("N0") Kč
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="EmployeeDto"
                                              Property="IsActive"
                                              Title="Stav"
                                              Width="100px">
                            <Template Context="emp">
                                <RadzenBadge BadgeStyle="@(emp.IsActive ? BadgeStyle.Success : BadgeStyle.Danger)"
                                             Text="@(emp.IsActive ? "Aktivní" : "Neaktivní")" />
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="EmployeeDto"
                                              Title="Akce"
                                              Width="150px"
                                              Filterable="false"
                                              Sortable="false">
                            <Template Context="emp">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                    <RadzenButton Icon="info"
                                                  ButtonStyle="ButtonStyle.Info"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => ShowEmployeeDetail(emp))"
                                                  title="Detail a zakázky" />
                                    <RadzenButton Icon="edit"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => EditEmployee(emp.Id))"
                                                  title="Upravit" />
                                    <RadzenButton Icon="delete"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => DeleteEmployee(emp.Id))"
                                                  title="Smazat" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }
    }
</RadzenStack>

@code {
    private List<EmployeeDto> allEmployees = new();
    private List<EmployeeDto> activeEmployees = new();
    private Dictionary<string, List<EmployeeDto>> groups = new();
    private bool isLoading = false;

    private static readonly Dictionary<string, int> PositionOrder = new()
    {
        { "Mistr výroby",    0 },
        { "Hlavní truhlář",  1 },
        { "Truhlář",         2 },
        { "Lakýrník",        3 },
        { "Montážník",       4 },
        { "Čalouník",        5 },
        { "Skladník",        6 },
        { "Řidič",           7 },
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        try
        {
            isLoading = true;
            var result = await Mediator.Send(new GetEmployeesQuery());
            allEmployees = result.ToList();
            activeEmployees = allEmployees.Where(e => e.IsActive).ToList();

            groups = allEmployees
                .GroupBy(e => e.Position)
                .OrderBy(g => PositionOrder.TryGetValue(g.Key, out var o) ? o : 99)
                .ToDictionary(g => g.Key, g => g.OrderBy(e => e.FullName).ToList());
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Chyba načítání",
                Detail = ex.Message,
                Duration = 4000
            });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowEmployeeDetail(EmployeeDto emp)
    {
        await DialogService.OpenAsync<EmployeeDetailDialog>(
            $"{emp.FullName} – detail",
            new Dictionary<string, object> { ["EmployeeId"] = emp.Id },
            new DialogOptions { Width = "750px", Height = "auto", Resizable = true, Draggable = true }
        );
    }

    private async Task CreateEmployee()
    {
        var result = await DialogService.OpenAsync<EmployeeEditDialog>(
            "Přidat zaměstnance",
            new Dictionary<string, object> { },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true }
        );

        if (result == true)
            await LoadEmployees();
    }

    private async Task EditEmployee(int employeeId)
    {
        var result = await DialogService.OpenAsync<EmployeeEditDialog>(
            "Upravit zaměstnance",
            new Dictionary<string, object> { ["EmployeeId"] = employeeId },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true }
        );

        if (result == true)
            await LoadEmployees();
    }

    private async Task DeleteEmployee(int employeeId)
    {
        var confirmed = await DialogService.Confirm(
            "Opravdu chcete smazat tohoto zaměstnance?",
            "Potvrzení smazání",
            new ConfirmOptions { OkButtonText = "Ano", CancelButtonText = "Ne" }
        );

        if (confirmed != true) return;

        try
        {
            await Mediator.Send(new DeleteEmployeeCommand(employeeId));
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Úspěch",
                Detail = "Zaměstnanec byl smazán",
                Duration = 3000
            });
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Chyba",
                Detail = ex.Message,
                Duration = 4000
            });
        }
    }
}
