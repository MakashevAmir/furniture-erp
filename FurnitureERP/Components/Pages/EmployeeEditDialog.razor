@using MediatR
@using FurnitureERP.Application.Employees.Queries.GetEmployeeById
@using FurnitureERP.Application.Employees.Commands.CreateEmployee
@using FurnitureERP.Application.Employees.Commands.UpdateEmployee
@inject IMediator Mediator
@inject NotificationService NotificationService
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <RadzenTemplateForm TItem="EmployeeFormModel" Data="@model" Submit="@OnSubmit">
        <RadzenStack Gap="0.5rem">
            <RadzenRow>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Jméno" Variant="Variant.Outlined">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="@model.FirstName" Name="FirstName" MaxLength="100" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="FirstName" Text="Jméno je povinné" />
                            <RadzenLengthValidator Component="FirstName" Max="100" Text="Maximum 100 znaků" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Příjmení" Variant="Variant.Outlined">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="@model.LastName" Name="LastName" MaxLength="100" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="LastName" Text="Příjmení je povinné" />
                            <RadzenLengthValidator Component="LastName" Max="100" Text="Maximum 100 znaků" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenFormField Text="Pozice" Variant="Variant.Outlined">
                <ChildContent>
                    <RadzenTextBox @bind-Value="@model.Position" Name="Position" MaxLength="100" Placeholder="Truhlář, Montážník..." />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="Position" Text="Pozice je povinná" />
                    <RadzenLengthValidator Component="Position" Max="100" Text="Maximum 100 znaků" />
                </Helper>
            </RadzenFormField>

            <RadzenFormField Text="Hodinová sazba (Kč/hod)" Variant="Variant.Outlined">
                <ChildContent>
                    <RadzenNumeric @bind-Value="@model.HourlyRate" Name="HourlyRate" Min="0" TValue="decimal" />
                </ChildContent>
                <Helper>
                    <RadzenRequiredValidator Component="HourlyRate" Text="Hodinová sazba je povinná" />
                    <RadzenNumericRangeValidator Component="HourlyRate" Min="0.01"
                                                  Text="Hodinová sazba musí být větší než 0" />
                </Helper>
            </RadzenFormField>

            <RadzenFormField Text="Stav" Variant="Variant.Outlined">
                <RadzenSwitch @bind-Value="@model.IsActive" Name="IsActive" />
                <RadzenLabel Text="@(model.IsActive ? "Aktivní" : "Neaktivní")"
                             Style="margin-left: 0.5rem;" Component="IsActive" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" style="margin-top: 1rem;">
            <RadzenButton ButtonType="ButtonType.Submit"
                          ButtonStyle="ButtonStyle.Primary"
                          Text="Uložit"
                          Icon="save"
                          IsBusy="@isSaving" />
            <RadzenButton ButtonType="ButtonType.Button"
                          ButtonStyle="ButtonStyle.Light"
                          Text="Zrušit"
                          Icon="cancel"
                          Click="@Cancel" />
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenStack>

@code {
    [Parameter]
    public int? EmployeeId { get; set; }

    private EmployeeFormModel model = new();
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (EmployeeId.HasValue)
        {
            await LoadEmployee(EmployeeId.Value);
        }
        else
        {
            model.IsActive = true;
        }
    }

    private async Task LoadEmployee(int id)
    {
        try
        {
            var query = new GetEmployeeByIdQuery(id);
            var employee = await Mediator.Send(query);

            if (employee != null)
            {
                model = new EmployeeFormModel
                {
                    FirstName = employee.FirstName,
                    LastName = employee.LastName,
                    Position = employee.Position,
                    HourlyRate = employee.HourlyRate,
                    IsActive = employee.IsActive
                };
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Chyba načítání",
                Detail = $"Nepodařilo se načíst zaměstnance: {ex.Message}",
                Duration = 4000
            });
            DialogService.Close(false);
        }
    }

    private async Task OnSubmit()
    {
        try
        {
            isSaving = true;

            if (EmployeeId.HasValue)
            {
                var command = new UpdateEmployeeCommand(
                    EmployeeId.Value,
                    model.FirstName,
                    model.LastName,
                    model.Position,
                    model.HourlyRate,
                    model.IsActive
                );
                await Mediator.Send(command);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Úspěch",
                    Detail = "Zaměstnanec byl úspěšně aktualizován",
                    Duration = 3000
                });
            }
            else
            {
                var command = new CreateEmployeeCommand(
                    model.FirstName,
                    model.LastName,
                    model.Position,
                    model.HourlyRate
                );
                await Mediator.Send(command);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Úspěch",
                    Detail = "Zaměstnanec byl úspěšně vytvořen",
                    Duration = 3000
                });
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Chyba ukládání",
                Detail = $"Nepodařilo se uložit zaměstnance: {ex.Message}",
                Duration = 4000
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }

    private class EmployeeFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Position { get; set; } = string.Empty;
        public decimal HourlyRate { get; set; }
        public bool IsActive { get; set; }
    }
}
